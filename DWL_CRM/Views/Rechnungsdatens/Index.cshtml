@model IEnumerable<DWL_CRM.Models.Rechnungsdaten>

@{
    ViewData["Title"] = "Rechnungen";
}

<div class="page-header">
    <h1 class="page-title">Rechnungen</h1>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">Rechnungseintrag anlegen</a>
    </div>
</div>

<div class="crm-card">
<div class="table-responsive">
<table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.RechnungenGesamt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RechnungenOffen)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LetzterZahlungseingang)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Firma)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.RechnungenGesamt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RechnungenOffen)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LetzterZahlungseingang)
            </td>
            <td>
                @(item.Firma?.Firmenname ?? "-")
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.RechnungsdatenId">Bearbeiten</a> |
                <a asp-action="Details" asp-route-id="@item.RechnungsdatenId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.RechnungsdatenId">Loeschen</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
</div>
