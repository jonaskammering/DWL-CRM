@model IEnumerable<DWL_CRM.ViewModels.FirmaIndexItemViewModel>

@{
    ViewData["Title"] = "Firmen";
    var currentQuery = ViewData["CurrentQuery"] as string;
    var currentAbc = ViewData["CurrentAbc"] as string;
    var currentSort = ViewData["CurrentSort"] as string;
}

<div class="page-header">
    <h1 class="page-title">Firmen</h1>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">Firma anlegen</a>
    </div>
</div>

<div class="crm-card">
<form method="get" class="row g-2 mb-3">
    <div class="col-12 col-md-5">
        <input class="form-control" type="text" name="q" value="@currentQuery" placeholder="Suche nach Firma, Branche oder Ort..." />
    </div>
    <div class="col-6 col-md-2">
        <select class="form-select" name="abc" asp-items="@(ViewData["AbcOptions"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"></select>
    </div>
    <div class="col-6 col-md-3">
        <select class="form-select" name="sort" asp-items="@(ViewData["SortOptions"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"></select>
    </div>
    <div class="col-12 col-md-2 d-grid d-md-flex gap-2">
        <button type="submit" class="btn btn-primary w-100">Filtern</button>
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
    </div>
</form>
<p class="text-muted mb-3">
    ABC-Kategorisierung nach kumuliertem Jahresumsatz:
    <span class="badge abc-badge abc-a">A</span> bis 80%,
    <span class="badge abc-badge abc-b">B</span> bis 95%,
    <span class="badge abc-badge abc-c">C</span> Rest.
</p>
<div class="table-responsive">
<table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>
                Firma
            </th>
            <th>
                ABC
            </th>
            <th>
                Strasse
            </th>
            <th>
                Branche
            </th>
            <th>
                Gruendungsdatum
            </th>
            <th>
                Jahresumsatz
            </th>
            <th>
                Bemerkungen
            </th>
            <th>
                Ort
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @item.Firma.Firmenname
            </td>
            <td>
                <span class="badge abc-badge abc-@item.AbcKategorie.ToLowerInvariant()">@item.AbcKategorie</span>
            </td>
            <td>
                @item.Firma.Strasse
            </td>
            <td>
                @item.Firma.Branche
            </td>
            <td>
                @item.Firma.Gruendungsdatum
            </td>
            <td>
                @item.Firma.Jahresumsatz
            </td>
            <td>
                @item.Firma.Bemerkungen
            </td>
            <td>
                @(item.Firma.Ort != null ? $"{item.Firma.Ort.Plz} {item.Firma.Ort.Ortsname}" : "-")
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Firma.FirmaId">Bearbeiten</a> |
                <a asp-action="Details" asp-route-id="@item.Firma.FirmaId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Firma.FirmaId">Loeschen</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
</div>
