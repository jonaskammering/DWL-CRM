@model IEnumerable<DWL_CRM.Models.Person>

@{
    ViewData["Title"] = "Personen";
    var currentQuery = ViewData["CurrentQuery"] as string;
    var currentSort = ViewData["CurrentSort"] as string;
}

<div class="page-header">
    <h1 class="page-title">Personen</h1>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">Person anlegen</a>
    </div>
</div>

<div class="crm-card">
<form method="get" class="row g-2 mb-3">
    <div class="col-12 col-lg-4">
        <input class="form-control" type="text" name="q" value="@currentQuery" placeholder="Suche nach Name, Telefon oder E-Mail..." />
    </div>
    <div class="col-12 col-lg-3">
        <select class="form-select" name="firmaId" asp-items="@(ViewData["FirmaFilter"] as SelectList)">
            <option value="">Alle Firmen</option>
        </select>
    </div>
    <div class="col-6 col-lg-3">
        <select class="form-select" name="sort" asp-items="@(ViewData["SortOptions"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"></select>
    </div>
    <div class="col-6 col-lg-2 d-grid d-md-flex gap-2">
        <button type="submit" class="btn btn-primary w-100">Filtern</button>
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
    </div>
</form>
<div class="table-responsive">
<table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Titel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vorname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nachname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Geburtsdatum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Telefon)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Firma)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Titel)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vorname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nachname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Geburtsdatum)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telefon)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @(item.Firma?.Firmenname ?? "-")
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.PersonId">Bearbeiten</a> |
                <a asp-action="Details" asp-route-id="@item.PersonId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.PersonId">Loeschen</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
</div>
