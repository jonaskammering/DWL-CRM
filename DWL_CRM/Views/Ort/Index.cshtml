@model IEnumerable<DWL_CRM.Models.Ort>

@{
    ViewData["Title"] = "Orte";
    var currentQuery = ViewData["CurrentQuery"] as string;
    var currentSort = ViewData["CurrentSort"] as string;
}

<div class="page-header">
    <h1 class="page-title">Orte</h1>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">Ort anlegen</a>
    </div>
</div>

<div class="crm-card">
<form method="get" class="row g-2 mb-3">
    <div class="col-12 col-md-7">
        <input class="form-control" type="text" name="q" value="@currentQuery" placeholder="Suche nach PLZ oder Ortsname..." />
    </div>
    <div class="col-6 col-md-3">
        <select class="form-select" name="sort" asp-items="@(ViewData["SortOptions"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"></select>
    </div>
    <div class="col-6 col-md-2 d-grid d-md-flex gap-2">
        <button type="submit" class="btn btn-primary w-100">Filtern</button>
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
    </div>
</form>
<div class="table-responsive">
<table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Plz)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Ortsname)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Plz)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Ortsname)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.OrtId">Bearbeiten</a> |
                <a asp-action="Details" asp-route-id="@item.OrtId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.OrtId">Loeschen</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
</div>
