@model IEnumerable<DWL_CRM.Models.Geschaeftsfuehrer>

@{
    ViewData["Title"] = "Geschaeftsfuehrer";
}

<div class="page-header">
    <h1 class="page-title">Geschaeftsfuehrer</h1>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">Zuordnung anlegen</a>
    </div>
</div>

<div class="crm-card">
<div class="table-responsive">
<table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Person)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @(item.Person != null ? $"{item.Person.Vorname} {item.Person.Nachname}".Trim() : "-")
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.GeschaeftsfuehrerId">Bearbeiten</a> |
                <a asp-action="Details" asp-route-id="@item.GeschaeftsfuehrerId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.GeschaeftsfuehrerId">Loeschen</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
</div>
